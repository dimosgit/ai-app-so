{
    "_version": "1.37.0",
    "sap.app": {
        "id": "salesorders",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "dataSources": {
            "mainService": {
                "uri": "/odata/v4/sales-order/",
                "type": "OData",
                "settings": {
                    "annotations": [
                        "annotation"
                    ],
                    "odataVersion": "4.0"
                }
            }
        },
        "crossNavigation": {
            "inbound": {
                "salesorders-display": {
                    "semanticObject": "SalesOrderReview",
                    "action": "display",
                    "title": "{{appTitle}}",
                    "subTitle": "Attention List",
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    }
                }
            }
        }
    },
    "sap.cloud": {
        "public": true,
        "service": "ai.app.so"
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "sap-icon://sales-order"
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.120.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.fe.templates": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "salesorders.i18n.i18n"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "synchronizationMode": "None",
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            }
        },
        "resources": {
            "css": []
        },
        "routing": {
            "config": {},
            "routes": [
                {
                    "pattern": ":?query:",
                    "name": "SalesOrdersList",
                    "target": "SalesOrdersList"
                },
                {
                    "pattern": "SalesOrders({key}):?query:",
                    "name": "SalesOrdersDetail",
                    "target": "SalesOrdersDetail"
                }
            ],
            "targets": {
                "SalesOrdersList": {
                    "type": "Component",
                    "id": "SalesOrdersList",
                    "namespace": "sap.fe.templates.ListReport",
                    "name": "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "entitySet": "SalesOrders",
                            "variantManagement": "None",
                            "navigation": {
                                "SalesOrders": {
                                    "detail": {
                                        "route": "SalesOrdersDetail"
                                    }
                                }
                            }
                        }
                    }
                },
                "SalesOrdersDetail": {
                    "type": "Component",
                    "id": "SalesOrdersDetail",
                    "namespace": "sap.fe.templates.ObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "entitySet": "SalesOrders",
                            "variantManagement": "None"
                        }
                    }
                }
            }
        }
    }
}