{
    "name": "salesorders",
    "version": "1.0.6",
    "description": "Sales Order Attention List UI",
    "devDependencies": {
        "@sap/ux-ui5-tooling": "1",
        "@ui5/cli": "^4.0.46",
        "ui5-task-zipper": "^3.5.1"
    },
    "scripts": {
        "start": "node ./node_modules/@sap/ux-ui5-tooling/bin/fiori run --config ui5.yaml --open 'test/flpSandbox.html?sap-ui-xx-viewCache=false#SalesOrderReview-display'",
        "build:cf": "ui5 build --config ui5-deploy.yaml --clean-dest --dest dist && node scripts/enrich-flp-namespace.js"
    },
    "sapux": true
}