{
    "welcomeFile": "/salesorders/index.html",
    "authenticationMethod": "route",
    "routes": [
        {
            "source": "^/odata/v4/sales-order/(.*)$",
            "target": "/odata/v4/sales-order/$1",
            "destination": "srv-api",
            "authenticationType": "xsuaa",
            "csrfProtection": true
        },
        {
            "source": "^/salesorders/(.*)$",
            "target": "aiappsosalesorders/$1",
            "service": "html5-apps-repo-rt",
            "authenticationType": "xsuaa"
        }
    ]
}