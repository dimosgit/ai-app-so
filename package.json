{
  "name": "ai-app-so",
  "version": "1.0.0",
  "description": "Sales Order Attention List",
  "repository": "https://github.com/dimosgit/ai-app-so",
  "license": "UNLICENSED",
  "dependencies": {
    "@sap/cds": "^8",
    "@sap/xsenv": "^5",
    "@sap/xssec": "^4",
    "express": "^4",
    "hdb": "^0",
    "passport": "^0"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "S4HANA_ODATA_SO": {
        "kind": "odata-v2",
        "model": "srv/external/S4HANA_ODATA_SO",
        "credentials": {
          "destination": "S4HANA_ODATA_SO"
        }
      }
    }
  }
}
