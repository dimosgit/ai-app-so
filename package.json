{
  "name": "ai-app-so",
  "version": "1.0.0",
  "description": "Sales Order Attention List",
  "repository": "https://github.com/dimosgit/ai-app-so",
  "license": "UNLICENSED",
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^4.5.1",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^8",
    "@sap/xsenv": "^5",
    "@sap/xssec": "^4",
    "express": "^4",
    "hdb": "^0",
    "passport": "^0"
  },
  "scripts": {
    "start": "cds-serve",
    "build": "cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sql"
      },
      "API_SALES_ORDER_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_SALES_ORDER_SRV",
        "credentials": {
          "destination": "S4HANA_ODATA_SO"
        }
      },
      "production": {
        "db": {
          "kind": "hana"
        }
      }
    }
  },
  "devDependencies": {
    "sqlite3": "^5.1.7"
  }
}